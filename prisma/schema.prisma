generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id                 String     @id @default(uuid())
  name               String
  date               String
  maxPrintsPerDevice Int        @default(5)
  active             Boolean    @default(true)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  photos             Photo[]
}

model Overlay {
  id        String   @id @default(uuid())
  name      String
  url       String
  createdAt DateTime @default(now())
  photos    Photo[]
}

model Photo {
  id               String   @id @default(uuid())
  eventId          String
  overlayId        String?
  photoUrl         String   @db.Text
  deviceId         String
  phoneNumber      String   @default("")
  status           String   @default("pending")
  moderationStatus String   @default("approved")   // approved | rejected | pending_review
  moderationReason String?
  printStatus      String   @default("not_sent")    // not_sent | sent | printed
  createdAt        DateTime @default(now())

  event            Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  overlay          Overlay? @relation(fields: [overlayId], references: [id])

  @@index([eventId])
  @@index([deviceId])
  @@index([phoneNumber])
}
